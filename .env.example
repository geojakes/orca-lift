# Copy to .env on the Synology NAS (alongside compose.yaml) and fill in.
# Container Manager Project loads .env automatically.

# Anthropic API key (pay-as-you-go). Required unless using a Claude Code OAuth
# token — see deploy/synology/README.md.
ANTHROPIC_API_KEY=

# Optional: Claude Code OAuth long-lived token. If set, the orca framework
# uses your Claude Code subscription instead of pay-as-you-go API billing.
# Generate on your workstation with `claude setup-token`.
# CLAUDE_CODE_OAUTH_TOKEN=

# Optional: NAS timezone (used for log timestamps).
TZ=America/Los_Angeles
